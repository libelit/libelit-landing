{
  "compilerOptions": {
    // Modern targets are fine for Next 13+; if you prefer, keep "es5".
    "target": "ES2020",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "esModuleInterop": true,

    // Next 13+ works with either "node" or "bundler".
    // "node" is fine; switch to "bundler" if you hit type resolution quirks with ESM packages.
    "module": "esnext",
    "moduleResolution": "node",

    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,

    // NEW: make alias intent explicit
    "baseUrl": ".",

    "typeRoots": ["./src/@types", "./node_modules/@types"],
    "plugins": [{ "name": "next" }],

    "paths": {
      "@/*": ["./src/*"],
      "@icons/*": ["./public/icons/*"],
      "library/*": ["./src/library/*"],
      "dictionaries/*": ["./dictionaries/*"],
      "components/*": ["./src/components/*"],
      "logos/*": ["./public/logo/*"],
      "icons/*": ["./public/icons/*"],
      "images/*": ["./public/images/*"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
``
